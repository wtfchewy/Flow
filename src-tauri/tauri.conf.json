{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peak",
  "version": "0.1.0",
  "identifier": "com.peak.notes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Untitled",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {},
    "updater": {
      "endpoints": [
        "https://github.com/wtfchewy/Peak/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2NUQ0MDEwRjVDM0Y2NEMKUldSTTlzUDFFRUJkSnY4VnVYdDA4VloxcDdEbFdPa0c5VzhnZG5XU2ZFcGZzdDFrWG93NFZxVUQK"
    }
  }
}